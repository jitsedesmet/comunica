{
  "name": "@comunica/query-sparql-cloudflare",
  "version": "5.1.3",
  "description": "A Cloudflare Workers wrapper for Comunica SPARQL query engine",
  "license": "MIT",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/comunica-association"
  },
  "homepage": "https://comunica.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/comunica/comunica.git",
    "directory": "engines/query-sparql-cloudflare"
  },
  "bugs": {
    "url": "https://github.com/comunica/comunica/issues"
  },
  "keywords": [
    "comunica",
    "sparql",
    "engine",
    "cloudflare",
    "workers",
    "edge",
    "serverless"
  ],
  "sideEffects": false,
  "main": "lib/index.js",
  "typings": "lib/index",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib/**/*.d.ts",
    "lib/**/*.js",
    "lib/**/*.js.map",
    "src/**/*.ts"
  ],
  "scripts": {
    "build": "npm run build:ts",
    "build:ts": "node \"../../node_modules/typescript/bin/tsc\"",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@comunica/query-sparql": "^5.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "wrangler": "^3.28.0"
  }
}
